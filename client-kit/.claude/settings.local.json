{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/sync_pull.py\" --repo \"$CLAUDE_PROJECT_DIR\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python3 *)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git push:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git rebase:*)",
      "Bash(git status:*)",
      "Bash(git log:*)"
    ]
  }
}
